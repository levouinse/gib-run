{
  "name": "gib-runs",
  "version": "3.0.1",
  "description": "Plugin-based development server with live reload - runs on merit, not nepotism",
  "keywords": [
    "development",
    "server",
    "live-reload",
    "hot-reload",
    "hmr",
    "http",
    "https",
    "http2",
    "spa",
    "cli",
    "devserver",
    "watch",
    "websocket",
    "performance",
    "compression",
    "proxy",
    "plugin",
    "extensible"
  ],
  "author": "sofinco (https://github.com/levouinse)",
  "dependencies": {
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "compression": "^1.7.4",
    "connect": "^3.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "event-stream": "^4.0.1",
    "faye-websocket": "^0.11.4",
    "http-auth": "^4.2.0",
    "js-yaml": "^4.1.0",
    "localtunnel": "^2.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "object-assign": "^4.1.1",
    "open": "^8.4.2",
    "ora": "^5.4.1",
    "proxy-middleware": "^0.15.0",
    "qrcode-terminal": "^0.12.0",
    "send": "^0.19.2",
    "serve-index": "^1.9.1"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "jshint": "^2.13.6",
    "mocha": "^11.0.1",
    "nyc": "^17.1.0",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "axios": "^1.7.9",
    "minimatch": "^10.0.1",
    "glob": "^11.0.0",
    "diff": "^7.0.0"
  },
  "scripts": {
    "lint": "eslint gib-run.js index.js core/**/*.js features/**/*.js lib/**/*.js",
    "hint": "jshint gib-run.js index.js",
    "test": "mocha test/*.js --exit && npm run lint",
    "test:coverage": "nyc mocha test/*.js --exit",
    "test:watch": "mocha test/*.js --watch"
  },
  "bin": {
    "gib-runs": "gib-run.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/levouinse/gib-runs.git"
  },
  "bugs": {
    "url": "https://github.com/levouinse/gib-runs/issues"
  },
  "homepage": "https://github.com/levouinse/gib-runs#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "preferGlobal": true,
  "license": "MIT",
  "eslintConfig": {
    "env": {
      "node": true,
      "es6": true
    },
    "parserOptions": {
      "ecmaVersion": 2020
    },
    "rules": {
      "quotes": 0,
      "curly": 0,
      "strict": 0,
      "no-process-exit": 0,
      "eqeqeq": 1,
      "no-unused-vars": 1,
      "no-shadow": 1
    }
  }
}
